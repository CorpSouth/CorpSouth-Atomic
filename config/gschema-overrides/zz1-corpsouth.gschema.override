[org.gnome.Console]
theme='auto'

[org.gnome.desktop.default-applications.terminal]
exec='kgx'
exec-arg='-e'

[org.gnome.desktop.interface]
gtk-theme='adw-gtk3'

[org.gnome.login-screen]
logo=''

[org.gnome.shell]
allow-extension-installation=false
disabled-extensions=['']
enabled-extensions=['']

[org.gnome.software]
allow-updates=false
download-updates=false
download-updates-notify=false
enable-repos-dialog=false
packaging-format-preference=['flatpak:flathub-user']
